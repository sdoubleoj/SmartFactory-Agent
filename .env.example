# Manufacturing AI Agent — 환경 변수 템플릿
# 이 파일을 .env 로 복사한 뒤 실제 값을 채워 넣으세요.
# .env 는 .gitignore 에 포함되어 커밋되지 않습니다.

# OpenAI API
OPENAI_API_KEY=

# LLM 설정
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0

# (선택) 경로 오버라이드 — 기본값은 ./artifacts/ 하위
# CHECKPOINT_DB=./artifacts/checkpoints.sqlite
# LONGTERM_DB=./artifacts/longterm.sqlite
# CHROMA_PATH=./artifacts/chroma

# (선택) LangSmith 트레이싱
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=manufacturing-agent-eval